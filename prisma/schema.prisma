// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map(name: "created_at")
  updatedAt         DateTime @default(now()) @map(name: "updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map(name: "accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map(name: "sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  preferences   Json?
  admin         Boolean   @default(false)
  createdAt     DateTime  @default(now()) @map(name: "created_at")
  updatedAt     DateTime  @default(now()) @map(name: "updated_at")
  access   Access[] //new tells what perms the user has
  accounts Account[] // other details like oauth, etc.
  sessions Session[] // active sessions
  posts    Post[] // posts by user
  exams    Exam[] // exams by user

  stripeCustomerId       String?   @unique @map(name: "stripe_customer_id")
  stripeSubscriptionId   String?   @unique @map(name: "stripe_subscription_id")
  stripePriceId          String?   @map(name: "stripe_price_id")
  stripeCurrentPeriodEnd DateTime? @map(name: "stripe_current_period_end")

  @@map(name: "users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map(name: "verification_tokens")
}

model Exam {
  id          String   @id @default(cuid())
  title       String
  start       DateTime
  end         DateTime
  duration    Int      @default(60)
  extratime   Int      @default(0)
  readingtime Int      @default(0)
  reminders   Json?
  extra       Json?
  createdAt   DateTime @default(now()) @map(name: "created_at")
  updatedAt   DateTime @default(now()) @map(name: "updated_at")
  authorId    String
  schoolId    String

  examsessions ExamSession[]
  school       School        @relation(fields: [schoolId], references: [id])
  author       User          @relation(fields: [authorId], references: [id])

  @@map(name: "exams")
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   Json?
  published Boolean  @default(false)
  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @default(now()) @map(name: "updated_at")
  authorId  String

  author User @relation(fields: [authorId], references: [id])

  @@map(name: "posts")
}

model Access {
  id     String  @id @default(cuid())
  userId String
  admin  Boolean @default(false)
  //schools

  user User @relation(fields: [userId], references: [id])
}

model School {
  id        String   @id @default(cuid())
  name      String
  location  Json?
  //...
  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @default(now()) @map(name: "updated_at")

  exams        Exam[]
  examsessions ExamSession[]
  students     Student[]

  @@map(name: "schools")
}

model Student {
  id        String   @id @default(cuid())
  userId    String
  schoolId  String
  //...
  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @default(now()) @map(name: "updated_at")

  school       School        @relation(fields: [schoolId], references: [id])
  seatingplan  SeatingPlan[]
  examsessions ExamSession[]

  @@map(name: "students")
}

model ExamSession {
  id        String   @id @default(cuid())
  examId    String
  schoolId  String
  start     DateTime
  end       DateTime
  //...
  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @default(now()) @map(name: "updated_at")

  seatingplan SeatingPlan[]
  students    Student[]
  exams       Exam          @relation(fields: [examId], references: [id])
  school      School        @relation(fields: [schoolId], references: [id])

  @@map(name: "exam_sessions")
}

model SeatingPlan {
  id            String @id @default(cuid())
  examSessionId String
  studentId     String

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @default(now()) @map(name: "updated_at")

  examSession ExamSession @relation(fields: [examSessionId], references: [id])
  students    Student     @relation(fields: [studentId], references: [id])

  @@map(name: "seating_plans")
}

model Test {
  id        Int      @id @default(autoincrement())
  testchar  String?
  testint   Int?
  testfloat Float?
  testdt    DateTime?
  testjson  Json?

  @@map(name: "test")
}